# =============================================================================
# PaperClaw environment configuration
# Copy to .env and fill in your values. .env is gitignored.
# =============================================================================

# ----- Claude / Anthropic (one of the two is required) -----------------------
# Long-lived OAuth token from `claude setup-token` (recommended)
CLAUDE_CODE_OAUTH_TOKEN=
# Or, pay-per-use API key from https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ----- WhatsApp --------------------------------------------------------------
# Your main WhatsApp JID. For an individual, this is <phone>@s.whatsapp.net
# (e.g. 821012345678@s.whatsapp.net). For a group chat, run `npx tsx
# setup/list-groups.ts` after auth to discover the @g.us JID.
CHAT_JID=

# ----- Notion ---------------------------------------------------------------
# Internal integration token: https://www.notion.so/my-integrations
NOTION_TOKEN=
# Research papers database ID (32-char hex). Either create the DB manually
# (see README Notion Setup) or run `npx tsx setup/bootstrap-notion.ts` to
# create it with the correct schema and have this var populated automatically.
NOTION_RESEARCH_DB=

# ----- Assistant identity ----------------------------------------------------
# Display name the agent uses when greeting users
ASSISTANT_NAME=PaperClaw
# Set true if the assistant has its own dedicated WhatsApp number, false if
# it shares yours.
ASSISTANT_HAS_OWN_NUMBER=false

# ----- Output language ------------------------------------------------------
# Controls how papers are processed and how the agent talks back.
#   ko       — translate paper content (Abstract, Method, etc.) into Korean
#              via NotebookLM. Default. Agent replies in Korean.
#   en       — DO NOT translate. Instead, reformat paper sections into
#              clean Notion-friendly English (proper headings, bullets,
#              equations preserved, citations stripped). Agent replies in
#              English. Use this if you read papers natively in English and
#              want Notion structure without translation cost.
#   ja|zh|de|fr|es|... (any other ISO code)
#            — translate paper content into that language.
OUTPUT_LANGUAGE=ko

# ----- Runtime knobs (all optional) ------------------------------------------
# Timezone for cron schedules and timestamps (IANA TZ name)
TZ=Asia/Seoul
# Logging: debug | info | warn | error
LOG_LEVEL=info
# Hard timeout per agent invocation (ms). Default 1800000 = 30 min.
CONTAINER_TIMEOUT=1800000
# Idle timeout — how long to keep a container alive waiting for follow-up
# messages from the same group (ms). Default 1800000 = 30 min.
IDLE_TIMEOUT=1800000
# Cap on simultaneous agent containers across all groups. Default 5.
MAX_CONCURRENT_CONTAINERS=5
# Override the agent container image tag (advanced)
# CONTAINER_IMAGE=paperclaw-agent:latest

# ----- Group folder ----------------------------------------------------------
# Subfolder under groups/ that holds your main channel's CLAUDE.md and data.
# You probably do not need to change this.
MAIN_GROUP_FOLDER=main
